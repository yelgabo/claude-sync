{
    "name":  "@claude-sync/desktop",
    "version":  "0.0.2",
    "private":  true,
    "type":  "module",
    "main":  "dist/main/index.js",
    "scripts":  {
                    "build":  "tsc -p tsconfig.json \u0026\u0026 node copy-renderer.cjs",
                    "start":  "electron .",
                    "dev":  "pnpm build \u0026\u0026 electron .",
                    "typecheck":  "tsc -p tsconfig.json --noEmit",
                    "test:e2e":  "node test/e2e.mjs",
                    "dist":  "pnpm build \u0026\u0026 electron-builder",
                    "dist:win":  "pnpm build \u0026\u0026 electron-builder --win",
                    "dist:mac":  "pnpm build \u0026\u0026 electron-builder --mac"
                },
    "dependencies":  {
                         "@claude-sync/cli":  "workspace:*",
                         "electron-updater":  "^6.3.9"
                     },
    "devDependencies":  {
                            "@types/node":  "^22.10.0",
                            "electron":  "^33.2.1",
                            "electron-builder":  "^25.1.8",
                            "playwright":  "^1.49.0",
                            "typescript":  "^5.7.2"
                        },
    "build":  {
                  "appId":  "app.claudesync",
                  "productName":  "Claude Sync",
                  "artifactName":  "claude-sync-${version}-${platform}-${arch}.${ext}",
                  "files":  [
                                "dist/**/*",
                                "package.json"
                            ],
                  "directories":  {
                                      "output":  "dist-installer"
                                  },
                  "win":  {
                              "target":  [
                                             {
                                                 "target":  "nsis",
                                                 "arch":  [
                                                              "x64"
                                                          ]
                                             }
                                         ],
                              "icon":  "../assets/icon-1024.png"
                          },
                  "mac":  {
                              "target":  [
                                             {
                                                 "target":  "dmg",
                                                 "arch":  [
                                                              "x64",
                                                              "arm64"
                                                          ]
                                             }
                                         ],
                              "category":  "public.app-category.developer-tools",
                              "icon":  "../assets/icon-1024.png",
                              "hardenedRuntime":  true,
                              "gatekeeperAssess":  false,
                              "entitlements":  "build/entitlements.mac.plist",
                              "entitlementsInherit":  "build/entitlements.mac.plist",
                              "notarize":  true
                          },
                  "nsis":  {
                               "oneClick":  false,
                               "perMachine":  false,
                               "allowToChangeInstallationDirectory":  true,
                               "deleteAppDataOnUninstall":  false
                           },
                  "publish":  [
                                  {
                                      "provider":  "github",
                                      "owner":  "yelgabo",
                                      "repo":  "claude-sync",
                                      "releaseType":  "release"
                                  }
                              ]
              }
}