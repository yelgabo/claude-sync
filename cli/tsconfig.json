{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "module":  "ESNext",
                            "moduleResolution":  "Bundler",
                            "lib":  [
                                        "ES2022"
                                    ],
                            "outDir":  "dist",
                            "rootDir":  "src",
                            "strict":  true,
                            "noUncheckedIndexedAccess":  true,
                            "esModuleInterop":  true,
                            "resolveJsonModule":  true,
                            "skipLibCheck":  true,
                            "declaration":  true,
                            "sourceMap":  true
                        },
    "include":  [
                    "src/**/*.ts"
                ]
}