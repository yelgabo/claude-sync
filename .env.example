# claude-sync server env vars

# Postgres (Railway provides DATABASE_URL automatically when you add a Postgres add-on)
DATABASE_URL=postgres://user:pass@localhost:5432/claude_sync

# Public URL the server is reachable at. Behind a proxy (Railway), set to the public https URL.
AUTH_URL=http://localhost:8080
AUTH_TRUST_HOST=false

# 32+ random bytes, base64url. Used to sign oauth_state cookies and back @fastify/cookie.
AUTH_SECRET=CHANGE_ME_32_byte_base64url_value

# GitHub OAuth (OPTIONAL). If both are set, /auth/github + /auth/github/callback register.
# Leave both empty to use email+password auth only (no /auth/github routes will exist).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Server
PORT=8080
NODE_ENV=development

# Rate limits (per minute)
RATE_LIMIT_AUTH_PER_IP=10
RATE_LIMIT_API_PER_USER=60

# Per-user storage quota (bytes); default 100 MiB
STORAGE_QUOTA_BYTES=104857600